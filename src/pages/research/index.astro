---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { profile, researchHighlights } from "../../data/site";
---

<BaseLayout
  title="Research | Jiading Zhu"
  description="Research by Jiading Zhu on generative AI, conversational agents, motivational interviewing, smoking cessation, and digital health."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Research</p>
      <h1>Generative AI for clinically grounded conversations</h1>
      <p class="lede">{profile.researchSummary}</p>
      <div class="button-row">
        <a class="button button-primary" href="https://www.eecg.utoronto.ca/~jayar/chatbot-for-smoking-cessation.html" rel="noreferrer" target="_blank">Project context</a>
        <a class="button" href="/publications/">Related publications</a>
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      <div class="grid three">
        {
          researchHighlights.map((highlight) => (
            <article class="card">
              <h2>{highlight.title}</h2>
              <p class="text-muted">{highlight.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid two">
        <article>
          <p class="eyebrow">Motivational interviewing</p>
          <h2>From chatbot responses to counselling quality</h2>
          <p>
            The smoking-cessation chatbot work uses motivational interviewing as a structured communication style. This creates technical questions about how language models should generate reflections, handle ambiguity, and support users without drifting away from clinically meaningful interaction patterns.
          </p>
          <p class="text-muted">
            The research program includes generative reflection generation, automated coding of counsellor and client behaviours, and evaluation of how people interact with AI counsellor systems.
          </p>
        </article>
        <article>
          <p class="eyebrow">Digital health</p>
          <h2>AI systems that meet real-world constraints</h2>
          <p>
            The work connects language-model methods with collaboration across engineering, CAMH, and University of Toronto health researchers. Observing clinical motivational interviewing sessions helps ground system design in the realities of smoking-cessation counselling.
          </p>
          <p class="text-muted">
            The broader goal is to make conversational agents more controllable, evaluable, and useful in sensitive domains where response quality matters.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

