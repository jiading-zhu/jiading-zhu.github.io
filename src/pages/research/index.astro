---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { profile, researchHighlights } from "../../data/site";
---

<BaseLayout
  title="Research | Jiading Zhu"
  description="Research by Jiading Zhu on LLM-based motivational interviewing, behavioural counselling, smoking cessation, and digital health."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Research</p>
      <h1>LLM harnesses for motivational interviewing</h1>
      <p class="lede">{profile.researchSummary}</p>
      <div class="button-row">
        <a class="button button-primary" href="https://www.eecg.utoronto.ca/~jayar/chatbot-for-smoking-cessation.html" rel="noreferrer" target="_blank">Project context</a>
        <a class="button" href="/publications/">Related publications</a>
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="container">
      <div class="grid three">
        {
          researchHighlights.map((highlight) => (
            <article class="card">
              <h2>{highlight.title}</h2>
              <p class="text-muted">{highlight.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid two">
        <article>
          <p class="eyebrow">Motivational interviewing</p>
          <h2>From generated responses to counselling behaviour</h2>
          <p>
            My work treats motivational interviewing as a structured behavioural counselling style, not just a chatbot tone. The technical problem is to build the prompts, control logic, evaluation harnesses, and transcript-analysis tools around LLMs so their generated counselling behaviour can stay closer to MI principles.
          </p>
          <p class="text-muted">
            The research program includes MI-style reflection generation, automated coding of counsellor and client behaviours, MI adherence evaluation, personalization, and studies of how people interact with these systems.
          </p>
        </article>
        <article>
          <p class="eyebrow">Digital health</p>
          <h2>Smoking cessation as the main testbed</h2>
          <p>
            Smoking cessation is the primary application context for this work because motivational interviewing is a validated counselling approach but skilled counselling is difficult to scale. The goal is to make LLM-based behavioural counselling more controllable, measurable, and clinically grounded.
          </p>
          <p class="text-muted">
            The work is developed with health collaborators, including CAMH, and emphasizes responsible evaluation before deployment.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
