---
import { profile } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Jiading Zhu | PhD Candidate, University of Toronto",
  description = profile.description,
} = Astro.props;

const pathname = Astro.url.pathname;
const canonical = new URL(pathname, "https://jiading-zhu.github.io").toString();
const navItems = [
  { label: "Home", href: "/" },
  { label: "Research", href: "/research/" },
  { label: "Publications", href: "/publications/" },
  { label: "CV", href: "/cv/" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://jiading-zhu.github.io/assets/jiading.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <nav class="nav" aria-label="Main navigation">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "nav-link",
                  pathname === item.href ||
                  (item.href !== "/" && pathname.startsWith(item.href))
                    ? "is-active"
                    : "",
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <p>&copy; {new Date().getFullYear()} Jiading Zhu</p>
        <div class="footer-links">
          <a href={`mailto:${profile.email}`}>Email</a>
          <a href="https://scholar.google.ca/citations?user=FDl9F6UAAAAJ&hl=en" rel="noreferrer" target="_blank">Scholar</a>
          <a href="https://www.linkedin.com/in/jiading-zhu/" rel="noreferrer" target="_blank">LinkedIn</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #17202a;
    --muted: #586575;
    --soft: #f6f8f8;
    --panel: #ffffff;
    --line: #d9e1e2;
    --accent: #0f766e;
    --accent-strong: #115e59;
    --blue: #1d4e89;
    --warm: #b45309;
    --shadow: 0 18px 45px rgba(23, 32, 42, 0.08);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: #ffffff;
    color: var(--ink);
    font-size: 16px;
    line-height: 1.65;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: var(--accent-strong);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  a:hover {
    color: var(--blue);
  }

  .container {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid rgba(217, 225, 226, 0.85);
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(14px);
  }

  .header-inner {
    display: flex;
    min-height: 72px;
    align-items: center;
    justify-content: flex-end;
    gap: 24px;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .nav-link {
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 650;
    padding: 6px 2px;
    text-decoration: none;
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--accent-strong);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.45em;
  }

  main {
    min-height: 70vh;
  }

  .section {
    padding: 72px 0;
  }

  .section.soft {
    background: var(--soft);
  }

  .section-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 28px;
  }

  .eyebrow {
    color: var(--warm);
    font-size: 0.82rem;
    font-weight: 800;
    margin: 0 0 10px;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1,
  h2,
  h3 {
    line-height: 1.15;
  }

  h1 {
    font-size: 3.25rem;
    margin-bottom: 18px;
  }

  h2 {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  h3 {
    font-size: 1.18rem;
    margin-bottom: 8px;
  }

  .lede {
    color: var(--muted);
    font-size: 1.15rem;
    max-width: 67ch;
  }

  .text-muted {
    color: var(--muted);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--ink);
    font-weight: 700;
    padding: 8px 14px;
    text-decoration: none;
  }

  .button:hover {
    border-color: var(--accent);
    color: var(--accent-strong);
  }

  .button-primary {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .button-primary:hover {
    background: var(--accent-strong);
    color: #fff;
  }

  .hero {
    padding: 66px 0 68px;
  }

  .hero-copy {
    max-width: 780px;
  }

  .hero-title-meta {
    color: var(--blue);
    font-size: 1.06rem;
    font-weight: 760;
    margin-bottom: 22px;
  }

  .title-lines {
    color: var(--blue);
    font-size: 1.02rem;
    font-weight: 760;
    line-height: 1.42;
    margin-bottom: 22px;
    max-width: 58ch;
  }

  .title-lines span {
    display: block;
  }

  .hero-identity {
    display: flex;
    align-items: center;
    gap: 22px;
    margin-bottom: 26px;
  }

  .portrait {
    width: 232px;
    height: 232px;
    border: 1px solid var(--line);
    border-radius: 50%;
    box-shadow: var(--shadow);
    flex: 0 0 auto;
    object-fit: cover;
    object-position: center center;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .tag {
    border: 1px solid #b7d8d3;
    border-radius: 999px;
    background: #eef8f6;
    color: var(--accent-strong);
    font-size: 0.83rem;
    font-weight: 760;
    padding: 5px 10px;
  }

  .contact-list {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ink);
    font-size: 0.96rem;
    font-weight: 700;
    text-decoration: none;
  }

  .contact-link:hover {
    color: var(--accent-strong);
  }

  .contact-icon {
    display: inline-grid;
    width: 26px;
    height: 26px;
    place-items: center;
    border-radius: 50%;
    background: #eef3f3;
    color: var(--accent-strong);
  }

  .contact-icon svg {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .contact-icon path[fill] {
    stroke: none;
  }

  .grid {
    display: grid;
    gap: 18px;
  }

  .grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid.three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .card {
    min-width: 0;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    padding: 22px;
  }

  .card:hover {
    border-color: #b9caca;
  }

  .card-meta {
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 650;
    margin-bottom: 8px;
  }

  .publication-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .publication-title {
    color: var(--ink);
    text-decoration: none;
  }

  .publication-title:hover {
    color: var(--accent-strong);
  }

  .publication-authors {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .author-self {
    border-radius: 4px;
    background: #fff3cf;
    color: #6d4d00;
    font-weight: 800;
    padding: 0 3px;
  }

  .publication-summary {
    color: var(--ink);
    font-size: 0.98rem;
  }

  .publication-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: auto;
  }

  .mini-tag {
    border-radius: 4px;
    background: #eef6f4;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 760;
    padding: 4px 9px;
  }

  .timeline {
    display: grid;
    gap: 16px;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 190px minmax(0, 1fr);
    gap: 24px;
    border-top: 1px solid var(--line);
    padding-top: 20px;
  }

  .timeline-date {
    color: var(--blue);
    font-size: 0.94rem;
    font-weight: 800;
  }

  .clean-list {
    margin: 12px 0 0;
    padding-left: 20px;
  }

  .clean-list li + li {
    margin-top: 6px;
  }

  .cv-header {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 24px;
    align-items: center;
    padding: 54px 0 34px;
  }

  .avatar {
    width: 220px;
    height: 220px;
    max-width: none;
    border-radius: 50%;
    border: 1px solid var(--line);
    object-fit: cover;
    object-position: center center;
  }

  .site-footer {
    border-top: 1px solid var(--line);
    background: #fff;
    color: var(--muted);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    min-height: 86px;
  }

  .footer-inner p {
    margin: 0;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  @media (max-width: 820px) {
    .container {
      width: min(100% - 28px, 1120px);
    }

    .header-inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
      padding: 14px 0;
    }

    .nav {
      justify-content: flex-start;
      width: 100%;
    }

    .hero {
      padding: 44px 0 56px;
    }

    .hero-identity {
      align-items: flex-start;
      flex-direction: column;
      gap: 16px;
    }

    .portrait {
      width: 204px;
      height: 204px;
    }

    h1 {
      font-size: 2.25rem;
    }

    h2 {
      font-size: 1.62rem;
    }

    .section {
      padding: 52px 0;
    }

    .section-header {
      display: block;
    }

    .grid.two,
    .grid.three {
      grid-template-columns: 1fr;
    }

    .timeline-item,
    .cv-header {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .footer-inner {
      align-items: flex-start;
      flex-direction: column;
      justify-content: center;
      padding: 22px 0;
    }
  }

  @media print {
    .site-header,
    .site-footer,
    .button-row {
      display: none;
    }

    body {
      color: #000;
    }

    .section {
      padding: 20px 0;
    }

    .card {
      border-color: #bbb;
      break-inside: avoid;
    }
  }
</style>
