---
interface Props {
  label: string;
  href: string;
  icon: string;
}

const { label, href, icon } = Astro.props;
const isExternal = href.startsWith("http");
---

<a class="contact-link" href={href} rel={isExternal ? "noreferrer" : undefined} target={isExternal ? "_blank" : undefined}>
  <span class="contact-icon" aria-hidden="true">
    {
      icon === "email" && (
        <svg viewBox="0 0 24 24" role="img">
          <path d="M4.75 6.75h14.5v10.5H4.75z" />
          <path d="m5.25 7.25 6.75 5.5 6.75-5.5" />
        </svg>
      )
    }
    {
      icon === "scholar" && (
        <svg viewBox="0 0 24 24" role="img">
          <path d="M12 4.25 3.75 8.5 12 12.75l8.25-4.25L12 4.25Z" />
          <path d="M7.25 10.75v4.1c0 1.6 2.13 2.9 4.75 2.9s4.75-1.3 4.75-2.9v-4.1" />
          <path d="M20.25 8.5v6" />
        </svg>
      )
    }
    {
      icon === "linkedin" && (
        <svg viewBox="0 0 24 24" role="img">
          <path d="M5.5 9.75h3v8.75h-3z" />
          <path d="M7 5.5a1.75 1.75 0 1 1 0 3.5 1.75 1.75 0 0 1 0-3.5Z" />
          <path d="M11.25 9.75h2.85v1.2c.46-.74 1.34-1.45 2.78-1.45 2.35 0 3.62 1.5 3.62 4.27v4.73h-3v-4.35c0-1.36-.5-2.04-1.55-2.04-.95 0-1.7.66-1.7 2.04v4.35h-3V9.75Z" />
        </svg>
      )
    }
  </span>
  <span>{label}</span>
</a>
